APP_NAME="AI Support SaaS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_support_saas
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=redis
CACHE_PREFIX=ai_support

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_RATE_LIMIT_DB=3

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# LLM Provider (openai | anthropic)
LLM_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1000

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_DAY=500000
RATE_LIMIT_TOKENS_PER_MINUTE=50000

# Queue Config
QUEUE_HIGH_PRIORITY=high
QUEUE_DEFAULT_PRIORITY=default
QUEUE_LOW_PRIORITY=low
QUEUE_FAILED_DRIVER=database
QUEUE_RETRY_AFTER=90
QUEUE_MAX_TRIES=3

# LLM Response Cache
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600

# Admin
ADMIN_API_KEY=
